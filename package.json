{
  "name": "dunna",
  "author": "Ali Mehasin",
  "license": "MIT",
  "type": "module",
  "version": "0.15.0",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "packageManager": "bun@1.3.12",
  "keywords": [
    "random",
    "fake",
    "data",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alimehasin/dunna.git"
  },
  "scripts": {
    "build": "bun run build:clean && bun run build:esm && bun run build:cjs && bun run build:types",
    "build:clean": "rm -rf dist",
    "build:esm": "bun build ./src/index.ts --outdir dist --format esm --target node --sourcemap=linked --entry-naming=[dir]/[name].mjs",
    "build:cjs": "bun build ./src/index.ts --outdir dist --format cjs --target node --sourcemap=linked --entry-naming=[dir]/[name].cjs",
    "build:types": "tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.mts && mv dist/index.d.ts dist/index.d.cts",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check --write",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "prepare": "husky",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build",
    "docs:clean": "cd docs && bun run clean",
    "scripts:cleanup": "scripts/cleanup.sh",
    "scripts:rmdeps": "scripts/rmdeps.sh",
    "scripts:update": "scripts/update.sh",
    "release": "release-it"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "release-it": "^20.0.0",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "1MB"
    }
  ]
}
