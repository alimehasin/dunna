{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignoreUnknown": false,
    "maxSize": 3000000
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "complexity": {
        "noImportantStyles": "off"
      }
    }
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },

  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
